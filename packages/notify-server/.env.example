# ─── Notify Server Configuration ────────────────────────────────────────────
# Copy to .env and fill in values. All variables are [REQUIRED] — this service
# refuses to start without them.

# ─── Database ───────────────────────────────────────────────────────────────

# PostgreSQL connection string [REQUIRED]
DATABASE_URL=postgres://notify:notify@localhost:5432/notify

# ─── Redis ──────────────────────────────────────────────────────────────────

# Redis URL [REQUIRED]
REDIS_URL=redis://localhost:6379

# ─── Push Server ────────────────────────────────────────────────────────────

# URL of the push server to route notifications through [REQUIRED]
PUSH_SERVER_URL=http://localhost:3000

# ─── Authentication ─────────────────────────────────────────────────────────

# JWT signing secret [REQUIRED]
JWT_SECRET=your-super-secret-jwt-signing-key-min-16-chars

# ─── Rate Limiting ──────────────────────────────────────────────────────────

# Max notifications per user per window
RATE_LIMIT_PER_USER=100

# Rate limit window in seconds
RATE_LIMIT_WINDOW_SECS=60
