# ─── Tx Indexer Configuration ───────────────────────────────────────────────
# Copy to .env and fill in values. The indexer is configured programmatically
# via IndexerConfig and RestApiConfig, but these env vars can be used for
# deployment and bootstrapping.

# ─── Server ─────────────────────────────────────────────────────────────────

# Bind host
TX_INDEXER_HOST=0.0.0.0

# Bind port
TX_INDEXER_PORT=3002

# Base path prefix for REST API
TX_INDEXER_BASE_PATH=/api/v1

# API key for REST authentication (optional; if set, requires Bearer token)
TX_INDEXER_API_KEY=

# ─── Database ───────────────────────────────────────────────────────────────

# Path to SQLite database file
TX_INDEXER_DB_PATH=./data/indexer.sqlite

# ─── Chain RPC Endpoints ────────────────────────────────────────────────────
# [REQUIRED] — At least one chain must be configured.
# Format: TX_CHAIN_<CHAIN_ID>=<RPC_URL>|<NAME>|<POLL_INTERVAL_MS>|<BATCH_SIZE>|<START_BLOCK>

# Ethereum Mainnet
TX_CHAIN_1=https://eth-mainnet.example.com/v1/YOUR_API_KEY|Ethereum|12000|500|0

# Polygon
TX_CHAIN_137=https://polygon-mainnet.example.com/v1/YOUR_API_KEY|Polygon|12000|500|0

# BSC
TX_CHAIN_56=https://bsc-mainnet.example.com/v1/YOUR_API_KEY|BSC|12000|500|0

# ─── CORS ───────────────────────────────────────────────────────────────────

# Comma-separated allowed origins (empty = hardcoded defaults)
TX_INDEXER_ALLOWED_ORIGINS=
