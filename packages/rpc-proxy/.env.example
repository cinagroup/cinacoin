# ─── RPC Proxy Configuration ────────────────────────────────────────────────
# Copy to .env and fill in values. The proxy is configured programmatically
# via RpcProxyConfig, but these env vars can be used to set up deployments.

# Server
# Bind host
RPC_PROXY_HOST=0.0.0.0

# Bind port
RPC_PROXY_PORT=8080

# Default chain for requests without chain routing
RPC_PROXY_DEFAULT_CHAIN=mainnet

# Cache TTL in milliseconds (0 = disabled)
RPC_PROXY_CACHE_TTL_MS=0

# Max requests per IP per minute (0 = disabled)
RPC_PROXY_RATE_LIMIT=100

# Maximum request body size in bytes (default: 1048576 = 1 MB)
RPC_PROXY_MAX_BODY_SIZE=1048576

# ─── Chain RPC Endpoints ────────────────────────────────────────────────────
# Map of chain name → RPC URL. Add as needed.

# Ethereum Mainnet
RPC_CHAIN_ETH=https://eth-mainnet.example.com/v1/YOUR_API_KEY

# Polygon
RPC_CHAIN_POLYGON=https://polygon-mainnet.example.com/v1/YOUR_API_KEY

# BSC (Binance Smart Chain)
RPC_CHAIN_BSC=https://bsc-mainnet.example.com/v1/YOUR_API_KEY

# Arbitrum One
RPC_CHAIN_ARBITRUM=https://arbitrum-mainnet.example.com/v1/YOUR_API_KEY

# Optimism
RPC_CHAIN_OPTIMISM=https://optimism-mainnet.example.com/v1/YOUR_API_KEY

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated allowed origin patterns (empty = all allowed)
# Use * suffix for wildcard matching, e.g. *.example.com
RPC_PROXY_ALLOWED_ORIGINS=
