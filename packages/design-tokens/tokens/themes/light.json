{
  "theme": {
    "name": "light",
    "mode": "light",
    "colors": {
      "--ocx-color-accent-100": "#DBEAFE",
      "--ocx-color-accent-500": "#2563EB",
      "--ocx-color-accent-600": "#1D4ED8",
      "--ocx-color-accent-glow": "rgba(37, 99, 235, 0.15)",
      "--ocx-color-bg-primary": "#FFFFFF",
      "--ocx-color-bg-secondary": "#F8FAFC",
      "--ocx-color-bg-tertiary": "#F1F5F9",
      "--ocx-color-bg-overlay": "rgba(0, 0, 0, 0.5)",
      "--ocx-color-bg-card": "#F8FAFC",
      "--ocx-color-bg-card-hover": "#F1F5F9",
      "--ocx-color-bg-input": "#FFFFFF",
      "--ocx-color-text-primary": "#0F172A",
      "--ocx-color-text-secondary": "#64748B",
      "--ocx-color-text-tertiary": "#94A3B8",
      "--ocx-color-text-inverse": "#FFFFFF",
      "--ocx-color-text-brand": "#2563EB",
      "--ocx-color-success": "#16A34A",
      "--ocx-color-success-bg": "rgba(22, 163, 74, 0.1)",
      "--ocx-color-warning": "#CA8A04",
      "--ocx-color-warning-bg": "rgba(202, 138, 4, 0.1)",
      "--ocx-color-error": "#DC2626",
      "--ocx-color-error-bg": "rgba(220, 38, 38, 0.1)",
      "--ocx-color-info": "#2563EB",
      "--ocx-color-info-bg": "rgba(37, 99, 235, 0.1)",
      "--ocx-color-border": "#E2E8F0",
      "--ocx-color-border-hover": "#CBD5E1",
      "--ocx-color-border-focus": "#2563EB"
    },
    "radii": {
      "--ocx-radius-sm": "0.25rem",
      "--ocx-radius-md": "0.5rem",
      "--ocx-radius-lg": "0.75rem",
      "--ocx-radius-xl": "1.5rem",
      "--ocx-radius-full": "9999px"
    },
    "shadows": {
      "--ocx-shadow-sm": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
      "--ocx-shadow-md": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1)",
      "--ocx-shadow-lg": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1)",
      "--ocx-shadow-glow": "0 0 20px rgba(37, 99, 235, 0.15)"
    },
    "typography": {
      "--ocx-font-family": "'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
      "--ocx-font-family-mono": "'JetBrains Mono', 'Fira Code', ui-monospace, monospace",
      "--ocx-font-size-xs": "0.75rem",
      "--ocx-font-size-sm": "0.875rem",
      "--ocx-font-size-md": "1rem",
      "--ocx-font-size-lg": "1.125rem",
      "--ocx-font-size-xl": "1.25rem",
      "--ocx-font-size-2xl": "1.5rem",
      "--ocx-font-weight-normal": "400",
      "--ocx-font-weight-medium": "500",
      "--ocx-font-weight-semibold": "600",
      "--ocx-font-weight-bold": "700"
    },
    "spacing": {
      "--ocx-space-1": "0.25rem",
      "--ocx-space-2": "0.5rem",
      "--ocx-space-3": "0.75rem",
      "--ocx-space-4": "1rem",
      "--ocx-space-6": "1.5rem",
      "--ocx-space-8": "2rem",
      "--ocx-space-10": "2.5rem",
      "--ocx-space-12": "3rem"
    },
    "animations": {
      "--ocx-duration-fast": "150ms",
      "--ocx-duration-normal": "250ms",
      "--ocx-duration-slow": "400ms",
      "--ocx-easing-default": "cubic-bezier(0.4, 0, 0.2, 1)",
      "--ocx-easing-spring": "cubic-bezier(0.175, 0.885, 0.32, 1.275)"
    },
    "z-index": {
      "--ocx-z-dropdown": "1000",
      "--ocx-z-modal-backdrop": "2000",
      "--ocx-z-modal": "2100",
      "--ocx-z-toast": "3000",
      "--ocx-z-tooltip": "4000"
    }
  }
}
