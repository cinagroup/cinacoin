# ─── Push Server Configuration ──────────────────────────────────────────────
# Copy to .env and fill in values. Lines marked [REQUIRED] must be set.

# ─── Server ─────────────────────────────────────────────────────────────────

# Bind host
PUSH_SERVER_HOST=0.0.0.0

# Bind port
PUSH_SERVER_PORT=3000

# Graceful shutdown timeout in seconds
PUSH_SHUTDOWN_TIMEOUT_SECS=30

# ─── APNs (Apple Push Notification service) ─────────────────────────────────
# [REQUIRED] — Must be configured for iOS push notifications.

# APNs team ID (10-char string from Apple Developer portal) [REQUIRED]
APNS_TEAM_ID=

# APNs key ID (10-char string for the .p8 key) [REQUIRED]
APNS_KEY_ID=

# Path to the APNs private key file (PKCS#8 .p8) [REQUIRED]
APNS_CERT_PATH=

# APNs bundle identifier (e.g. "com.example.app") [REQUIRED]
APNS_TOPIC=

# APNs environment: "production" or "development"
APNS_ENVIRONMENT=production

# Base URL for APNs (Apple manages this; override for testing only)
APNS_BASE_URL=https://api.push.apple.com

# ─── FCM (Firebase Cloud Messaging) ─────────────────────────────────────────
# [REQUIRED] — Must be configured for Android push notifications.

# Firebase Cloud Messaging project ID [REQUIRED]
FCM_PROJECT_ID=

# Path to Firebase service account JSON key file [REQUIRED]
FCM_SERVICE_ACCOUNT_PATH=

# ─── Redis ──────────────────────────────────────────────────────────────────

# Redis URL for device token caching and rate limiting
REDIS_URL=redis://localhost:6379

# ─── Rate Limiting ──────────────────────────────────────────────────────────

# Max push requests per minute per device token
PUSH_RATE_LIMIT_PER_DEVICE=60

# Max push requests per minute per app
PUSH_RATE_LIMIT_PER_APP=1000

# Rate limit window in seconds
PUSH_RATE_LIMIT_WINDOW_SECS=60

# ─── Retry Policy ───────────────────────────────────────────────────────────

# Max retry attempts for transient push failures
PUSH_RETRY_MAX_ATTEMPTS=3

# Initial retry delay in milliseconds
PUSH_RETRY_INITIAL_DELAY_MS=500

# Max retry delay in milliseconds
PUSH_RETRY_MAX_DELAY_MS=30000

# Retry backoff multiplier
PUSH_RETRY_BACKOFF_MULTIPLIER=2.0

# ─── Delivery Receipts ──────────────────────────────────────────────────────

# Whether to store delivery receipts in Redis
PUSH_DELIVERY_RECEIPT_ENABLED=true

# TTL for delivery receipts in seconds (default: 604800 = 7 days)
PUSH_DELIVERY_RECEIPT_TTL_SECS=604800

# ─── Metrics ────────────────────────────────────────────────────────────────

# Prometheus metrics endpoint path
PUSH_METRICS_PATH=/metrics
