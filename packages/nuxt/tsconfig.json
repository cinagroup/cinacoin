{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "#imports": ["./src/runtime/imports"],
      "#app": ["./node_modules/nuxt/dist/app"]
    },
    "types": ["nuxt", "@nuxt/kit"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules", "playground"]
}
