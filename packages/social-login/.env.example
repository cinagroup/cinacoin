# ─── Social Login Configuration ─────────────────────────────────────────────
# Copy to .env and fill in values.
# These env vars are referenced in example code within the package.
# Configuration is typically passed programmatically, but these are common
# deployment values.

# ─── Session ────────────────────────────────────────────────────────────────

# Session signing secret [REQUIRED for session-based auth]
SESSION_SECRET=your-session-secret-change-this

# ─── Google OAuth ───────────────────────────────────────────────────────────

# Google OAuth Client ID from Google Cloud Console
GOOGLE_CLIENT_ID=

# ─── Apple Sign-In ──────────────────────────────────────────────────────────

# Apple Sign-In Client ID (Services ID from developer.apple.com)
APPLE_CLIENT_ID=

# ─── Twitter/X OAuth ────────────────────────────────────────────────────────

# Twitter API Bearer Token (from developer.twitter.com)
TWITTER_BEARER_TOKEN=

# ─── Magic Link (Email OTP) ─────────────────────────────────────────────────

# Secret for signing magic link tokens
MAGIC_LINK_SECRET=your-magic-link-signing-secret

# ─── SMS Providers ──────────────────────────────────────────────────────────
# Only configure the provider(s) you use.

# -- Twilio --
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# -- Vonage (Nexmo) --
VONAGE_API_KEY=
VONAGE_API_SECRET=

# -- AWS SNS --
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
