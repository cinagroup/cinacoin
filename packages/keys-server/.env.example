# ─── Keys Server Configuration ──────────────────────────────────────────────
# Copy to .env and fill in values. Lines marked [REQUIRED] must be set.

# ─── Server ─────────────────────────────────────────────────────────────────

# Bind host
KEYS_SERVER_HOST=0.0.0.0

# Bind port
KEYS_SERVER_PORT=3001

# Graceful shutdown timeout in seconds
KEYS_SHUTDOWN_TIMEOUT_SECS=30

# ─── Database ───────────────────────────────────────────────────────────────

# PostgreSQL connection string [REQUIRED for production]
DATABASE_URL=postgres://keys:keys@localhost:5432/keys

# Maximum database connection pool size
DATABASE_MAX_CONNECTIONS=20

# ─── Redis ──────────────────────────────────────────────────────────────────

# Redis URL for caching
REDIS_URL=redis://localhost:6379

# Redis cache TTL in seconds
REDIS_CACHE_TTL_SECS=300

# ─── Authentication ─────────────────────────────────────────────────────────

# JWT signing secret — must be at least 16 characters [REQUIRED]
JWT_SECRET=your-super-secret-jwt-signing-key-min-16-chars

# JWT token expiry in seconds (default: 3600 = 1 hour)
JWT_EXPIRY_SECS=3600

# ─── Rate Limiting ──────────────────────────────────────────────────────────

# Max requests per IP per window
KEYS_RATE_LIMIT_PER_IP=100

# Rate limit window in seconds
KEYS_RATE_LIMIT_WINDOW_SECS=60

# ─── Key Management ─────────────────────────────────────────────────────────

# Default key algorithm: "ed25519" or "secp256k1"
DEFAULT_KEY_ALGORITHM=ed25519

# Max keys per wallet
MAX_KEYS_PER_WALLET=10

# ─── Metrics ────────────────────────────────────────────────────────────────

# Prometheus metrics endpoint path
KEYS_METRICS_PATH=/metrics
