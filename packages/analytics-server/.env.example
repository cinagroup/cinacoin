# ─── Analytics Server Configuration (Cloudflare Workers) ─────────────────────
# Copy to .env and fill in values.
# This service runs on Cloudflare Workers — env vars are mapped to
# wrangler.toml bindings, not process.env.
#
# Required wrangler.toml bindings:
#   [[d1_databases]]
#     binding = "DB"
#   [[kv_namespaces]]
#     binding = "RATE_LIMIT_KV"
#   [[kv_namespaces]]
#     binding = "DEDUP_KV"

# API key for request authentication (set in Cloudflare dashboard / wrangler.toml)
# Workers: set as a plain text binding in wrangler.toml vars
ANALYTICS_API_KEY=

# Max events per app_id per rate window (default: 1000)
ANALYTICS_RATE_LIMIT=1000

# Rate window in seconds (default: 3600 = 1 hour)
ANALYTICS_RATE_WINDOW=3600

# Batch insert size for D1 writes (default: 100)
ANALYTICS_BATCH_SIZE=100

# GDPR anonymization toggle ("false" to disable, anything else enables it)
ANALYTICS_GDPR_ANONYMIZE=true
