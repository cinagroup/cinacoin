# ─── Relay Server Configuration ──────────────────────────────────────────────
# Copy to .env and fill in values. Lines without defaults are REQUIRED.

# Server
# Bind address for HTTP/WebSocket listener
RELAY_LISTEN_ADDR=0.0.0.0:8080

# Redis URL for session storage and topic subscription tracking (REQUIRED)
RELAY_REDIS_URL=redis://127.0.0.1:6379

# NATS URL for Pub/Sub bus (optional — falls back to Redis-only)
RELAY_NATS_URL=

# Deployment region identifier (e.g., "us-east-1")
RELAY_REGION=local

# Public WebSocket URL exposed to clients in pairing URIs
RELAY_PUBLIC_URL=ws://localhost:8080

# Project identifier for namespace isolation
RELAY_PROJECT_ID=default

# TLS certificate and key paths (optional — when both set, enables WSS)
RELAY_TLS_CERT=
RELAY_TLS_KEY=

# ─── Rate Limiting ───────────────────────────────────────────────────────────

# Max new connections per IP per window
RELAY_CONNECTION_RATE_LIMIT=100

# Rate limit window in seconds
RELAY_CONNECTION_RATE_WINDOW_SECS=60

# ─── Message Size Limits ────────────────────────────────────────────────────

# Maximum incoming message size in bytes (default: 262144 = 256 KB)
RELAY_MAX_MESSAGE_SIZE=262144

# Maximum outgoing message size in bytes (default: 524288 = 512 KB)
RELAY_MAX_OUTGOING_SIZE=524288

# ─── Topic Expiration ───────────────────────────────────────────────────────

# Default topic TTL in seconds (0 = no expiration, default: 86400 = 24h)
RELAY_TOPIC_TTL_SECS=86400

# Topic cleanup interval in seconds (default: 300 = 5min)
RELAY_TOPIC_CLEANUP_INTERVAL=300

# ─── Persistent Storage ─────────────────────────────────────────────────────

# Whether to persist sessions to PostgreSQL
RELAY_SESSION_PERSISTENCE=false

# PostgreSQL connection string for session persistence (required if persistence enabled)
RELAY_DATABASE_URL=

# ─── Graceful Shutdown ──────────────────────────────────────────────────────

# Timeout in seconds for graceful shutdown
RELAY_SHUTDOWN_TIMEOUT_SECS=30

# ─── Metrics ────────────────────────────────────────────────────────────────

# Prometheus metrics scrape port (0 = same as listen_addr)
RELAY_METRICS_PORT=0
